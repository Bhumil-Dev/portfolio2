# ─── API URL ───────────────────────────────────────────────────
# LOCAL DEV: leave empty → Vite proxy handles /api → localhost:5000
# PRODUCTION: set to your Render backend URL (NO trailing slash, NO /api)
#
# The frontend automatically appends "/api" to this value.
# Final URL: VITE_API_URL + "/api/..."
#
# Examples:
#   Local dev:   VITE_API_URL=          (empty)
#   Production:  VITE_API_URL=https://your-backend.onrender.com

VITE_API_URL=
